# Fish syntax highlighting colors

set -g fish_color_normal normal
set -g fish_color_command normal
set -g fish_color_param normal
set -g fish_color_keyword F7A967 --italic
set -g fish_color_quote 94DFF7
set -g fish_color_redirection 94DFF7
set -g fish_color_end F7A967
set -g fish_color_error CABBED
set -g fish_color_valid_path F7B5C7 --underline
set -g fish_color_comment 54846B
set -g fish_color_selection --background=brblack
set -g fish_color_search_match --background=brblack
set -g fish_color_operator F7A967
set -g fish_color_escape F7A967
set -g fish_color_autosuggestion 666666
set -g fish_color_cancel F7B5C7
