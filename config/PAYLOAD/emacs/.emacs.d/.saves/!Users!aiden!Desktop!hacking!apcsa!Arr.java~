public class Arr {
    public static int s2(int []arr) {
        int k=0;
        for (int i=0; i<arr.length; i+=2) {
            k += arr[i];
        } return k;
    }
    
    public static void main(String args[]) {
        int[] a = {1, 2, 3, 4, 5, 6, 7};
        System.out.println(s2(a));
    }
}